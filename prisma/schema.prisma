generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model User {
  id            String    @id @default(uuid())
  name          String
  lastName      String    @map("last_name")
  email         String    @unique
  phone         String?
  passwordHash  String    @map("password_hash")
  roleId        String    @map("role_id")
  active        Boolean   @default(true)
  deleted       Boolean   @default(false)
  loginAttempts Int       @default(0) @map("login_attempts")
  blockedUntil  DateTime? @map("blocked_until") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  movements InventoryMovement[]

  role                Role                     @relation(fields: [roleId], references: [id])
  permissionOverrides UserPermissionOverride[]  @relation("UserOverrides")
  grantedOverrides    UserPermissionOverride[]  @relation("GrantedByUser")

  @@map("users")
}

model Module {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  path        String?
  parentId    String?  @map("parent_id")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")

  parent      Module?  @relation("ModuleHierarchy", fields: [parentId], references: [id])
  children    Module[] @relation("ModuleHierarchy")
  permissions RolePermission[]
  overrides   UserPermissionOverride[]

  @@map("modules")
}

model RolePermission {
  id         String   @id @default(uuid())
  roleId     String   @map("role_id")
  moduleId   String   @map("module_id")
  canView    Boolean  @default(false) @map("can_view")
  canCreate  Boolean  @default(false) @map("can_create")
  canEdit    Boolean  @default(false) @map("can_edit")
  canDelete  Boolean  @default(false) @map("can_delete")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(3)

  role   Role   @relation(fields: [roleId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([roleId, moduleId])
  @@map("role_permissions")
}

model UserPermissionOverride {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  moduleId     String    @map("module_id")
  canView      Boolean   @default(false) @map("can_view")
  canCreate    Boolean   @default(false) @map("can_create")
  canEdit      Boolean   @default(false) @map("can_edit")
  canDelete    Boolean   @default(false) @map("can_delete")
  overrideType String    @map("override_type")
  reason       String?
  grantedBy    String    @map("granted_by")
  grantedAt    DateTime  @default(now()) @map("granted_at") @db.Timestamptz(3)
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz(3)

  user    User   @relation("UserOverrides", fields: [userId], references: [id])
  module  Module @relation(fields: [moduleId], references: [id])
  grantor User   @relation("GrantedByUser", fields: [grantedBy], references: [id])

  @@map("user_permission_overrides")
}

model Supplier {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(180)
  rfc         String?  @db.VarChar(13)
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(180)
  contactName String?  @map("contact_name") @db.VarChar(120)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  batches       Batch[]

  @@map("suppliers")
}

model Supply {
  id            String   @id @default(uuid())
  code          String   @unique @db.VarChar(40)
  name          String   @db.VarChar(180)
  type          String   @db.VarChar(20)   // fabric | thread | zipper | button | interfacing | ink | stationery | accessory | other
  unitMeasure   String   @map("unidad_medida") @db.VarChar(30) // meter | piece | cone | kg | roll
  minStock      Decimal  @default(0) @map("stock_minimo") @db.Decimal(10, 2)
  currentStock  Decimal  @default(0) @map("stock_actual") @db.Decimal(10, 2)
  durationDays  Int?     @map("dias_duracion")
  isActive      Boolean  @default(true) @map("activo")
  createdAt     DateTime @default(now()) @map("creado_en")

  batches       Batch[]

  @@map("insumos")
}

model Batch {
  id               String   @id @default(uuid())
  supplyId         String   @map("insumo_id")
  supplierId       String   @map("proveedor_id")
  purchaseOrderId  String?  @map("orden_compra_id")
  batchNumber      String   @unique @map("numero_lote")
  season           String?  @db.VarChar(60)
  toneRange        String?  @map("rango_tono") @db.VarChar(60)
  color            String?  @db.VarChar(60)
  initialQuantity  Decimal  @map("cantidad_inicial") @db.Decimal(10,2)
  currentQuantity  Decimal  @map("cantidad_actual") @db.Decimal(10,2)
  warehouseLocation String? @map("ubicacion_almacen") @db.VarChar(80)
  entryDate        DateTime @map("fecha_entrada")
  notes            String?
  createdAt        DateTime @default(now()) @map("creado_en")

  movements InventoryMovement[]

  supply   Supply  @relation(fields: [supplyId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("lotes")
}

model InventoryMovement {
  id          String   @id @default(uuid())
  batchId     String   @map("lote_id")
  userId      String   @map("usuario_id")
  referenceId String?  @map("referencia_id")
  type        String   @db.VarChar(10) // entry | exit | adjustment | loss
  quantity    Decimal  @db.Decimal(10,2)
  reason      String?
  createdAt   DateTime @default(now()) @map("fecha")

  batch Batch @relation(fields: [batchId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("movimientos_inventario")
}